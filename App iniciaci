const SkillRadar = ({ habilidades, darkMode }) => {
  const max = 100;
  // Lógica de equilibrio: Si la desviación es pequeña, el nivel sube.
  const valores = Object.values(habilidades);
  const minVal = Math.min(...valores);
  const esEquilibrado = (Math.max(...valores) - minVal) < 25;

  return (
    <div className="flex flex-col items-center">
      <div className="relative w-48 h-48 flex items-center justify-center border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-full">
        {/* Vértice: Carrera */}
        <div className="absolute top-0 flex flex-col items-center" style={{ transform: 'translateY(-20px)' }}>
          <span className="text-[10px] font-bold uppercase text-red-500">Carrera</span>
          <div className="w-3 bg-red-500 rounded-full transition-all duration-700" style={{ height: `${habilidades.carreras}px` }} />
        </div>
        {/* Vértice: Salto */}
        <div className="absolute bottom-0 left-0 flex flex-col items-center" style={{ transform: 'translate(-10px, 10px)' }}>
          <div className="w-3 bg-blue-500 rounded-full transition-all duration-700" style={{ height: `${habilidades.saltos}px` }} />
          <span className="text-[10px] font-bold uppercase text-blue-500">Salto</span>
        </div>
        {/* Vértice: Lanzamiento */}
        <div className="absolute bottom-0 right-0 flex flex-col items-center" style={{ transform: 'translate(10px, 10px)' }}>
          <div className="w-3 bg-amber-500 rounded-full transition-all duration-700" style={{ height: `${habilidades.lanzamientos}px` }} />
          <span className="text-[10px] font-bold uppercase text-amber-500">Lanz.</span>
        </div>
       
        <div className={`text-center ${darkMode ? 'text-white' : 'text-slate-800'}`}>
          <p className="text-xs font-bold">Nivel</p>
          <p className="text-2xl font-black">{esEquilibrado ? 'A+' : 'B'}</p>
        </div>
      </div>
      <p className={`mt-4 text-xs font-medium px-3 py-1 rounded-full ${esEquilibrado ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500'}`}>
        {esEquilibrado ? "✨ Desarrollo Equilibrado" : "⚖️ Busca Variedad Motriz"}
      </p>
    </div>
  );
};

